# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).
# ============================================================

# --- Docker Hub ---
DOCKER_HUB_USER=seu_usuario_dockerhub
DOCKER_HUB_PASS=seu_token_dockerhub
IMAGE_NAME=pokemon-api

# --- SonarQube ---
# URL interna (via docker-compose) ou externa
SONAR_HOST_URL=http://sonarqube:9000
# Token gerado em: SonarQube UI → My Account → Security → Generate Token
SONAR_TOKEN=

# --- SMTP (notificação de e-mail) ---
# Gmail: crie uma "Senha de app" em myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
NOTIFICATION_EMAIL=destino@email.com

# --- Banco de dados SonarQube (interno) ---
POSTGRES_USER=sonar
POSTGRES_PASSWORD=sonar
POSTGRES_DB=sonar
